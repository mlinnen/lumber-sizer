# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
.squad/.cache/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Ignore build output and intermediate files
bin/
obj/
**/bin/
**/obj/

# IDE and OS files
.vs/
.vscode/
*.user
*.suo
*.DS_Store

# Test result artifacts
**/TestResults/
*.trx

# Generated export artifacts (GUID-named, produced by CLI/e2e runs)
artifacts/cli_export_*.html
artifacts/e2e_export_*.html

# Runtime test output files (GUID-named, produced during test runs)
tests/**/runtime_simple_cutlist_*.txt
